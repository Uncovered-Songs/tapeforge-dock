# Copy to .env and adjust for your environment.
APP_NAME="TapeForge Dock API"
ENVIRONMENT=development
DEBUG=true

API_V1_PREFIX=/api/v1

# SQLAlchemy/SQLModel database URL (defaults to a local SQLite file).
DATABASE_URL=sqlite:///./data/dock.db

# JSON array of allowed CORS origins (the Dock Vue dev server).
CORS_ORIGINS=["http://localhost:5174","http://127.0.0.1:5174"]
